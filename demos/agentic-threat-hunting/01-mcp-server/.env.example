# Azure AD App Registration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret

# Microsoft Sentinel / Log Analytics Workspace
SENTINEL_WORKSPACE_ID=your-log-analytics-workspace-id
SENTINEL_SUBSCRIPTION_ID=your-azure-subscription-id
SENTINEL_RESOURCE_GROUP=your-resource-group-name
SENTINEL_WORKSPACE_NAME=your-sentinel-workspace-name

# Optional: restrict KQL queries to read-only tables (comma-separated prefix allowlist)
KQL_TABLE_ALLOWLIST=SigninLogs,SecurityAlert,SecurityIncident,IdentityLogonEvents,AuditLogs

# Transport: stdio (default) or sse
MCP_TRANSPORT=stdio
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=8080
